# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HMAC signing key for the short-lived registration token issued by
# /api/auth/register/verify-otp. Optional — when unset, the registration
# flow falls back to SUPABASE_SERVICE_ROLE_KEY. Set this to rotate the
# token-signing secret independently of Supabase.
REGISTRATION_TOKEN_SECRET=

# Cloudflare — one set per TLD. Add a new set when adding a TLD.
CF_SITES_BD_API_TOKEN=
CF_SITES_BD_ZONE_ID=
CF_SITES_BD_ZONE_NAME=sites.bd

CF_ESITE_TOP_API_TOKEN=
CF_ESITE_TOP_ZONE_ID=
CF_ESITE_TOP_ZONE_NAME=esite.top

CF_ESITE_IN_API_TOKEN=
CF_ESITE_IN_ZONE_ID=
CF_ESITE_IN_ZONE_NAME=esite.in

# System nameservers (used when user picks "name_server" mode — system NS for each TLD;
# if all TLDs share the same NS pair, use these)
SYSTEM_NS_1=ns1.sites.bd
SYSTEM_NS_2=ns2.sites.bd

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp / Misc
ADMIN_WHATSAPP_NUMBER=
# Development / preview deployment is reachable via the custom subdomain
# `work.sites.bd` (some BD ISPs block the `*.vercel.app` subdomain at the
# network layer — see README "Dev domain" section). Production switches
# these to https://sites.bd / https://sites.bd/admin once the marketing
# site moves over.
APP_BASE_URL=https://work.sites.bd
ADMIN_BASE_URL=https://work.sites.bd/admin
CRON_SECRET=
