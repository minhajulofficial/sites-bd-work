# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare — one set per TLD. Add a new set when adding a TLD.
CF_SITES_BD_API_TOKEN=
CF_SITES_BD_ZONE_ID=
CF_SITES_BD_ZONE_NAME=sites.bd

CF_ESITE_TOP_API_TOKEN=
CF_ESITE_TOP_ZONE_ID=
CF_ESITE_TOP_ZONE_NAME=esite.top

CF_ESITE_IN_API_TOKEN=
CF_ESITE_IN_ZONE_ID=
CF_ESITE_IN_ZONE_NAME=esite.in

# System nameservers (used when user picks "name_server" mode — system NS for each TLD;
# if all TLDs share the same NS pair, use these)
SYSTEM_NS_1=ns1.sites.bd
SYSTEM_NS_2=ns2.sites.bd

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp / Misc
ADMIN_WHATSAPP_NUMBER=
APP_BASE_URL=https://sites-bd-work.vercel.app
ADMIN_BASE_URL=https://sites-bd-work.vercel.app/admin
CRON_SECRET=
